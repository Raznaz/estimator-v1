// Prisma schema для Planning Poker.
// Документация: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoomStatus {
  ACTIVE
  CLOSED
}

enum ParticipantRole {
  VOTER
  SPECTATOR
}

enum TicketStatus {
  PENDING
  VOTING
  ESTIMATED
  SKIPPED
}

enum RoundStatus {
  VOTING
  REVEALED
}

enum ScaleType {
  FIBONACCI
  MODIFIED_FIBONACCI
  T_SHIRT
  POWERS_OF_TWO
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  createdAt DateTime @default(now())

  ownedRooms   Room[]        @relation("RoomOwner")
  participants Participant[]
}

model Room {
  id        String     @id @default(cuid())
  name      String
  code      String     @unique
  scaleType ScaleType  @default(FIBONACCI)
  status    RoomStatus @default(ACTIVE)
  createdAt DateTime   @default(now())

  ownerId String
  owner   User   @relation("RoomOwner", fields: [ownerId], references: [id])

  participants Participant[]
  tickets      Ticket[]

  @@index([ownerId])
}

model Participant {
  id       String          @id @default(cuid())
  role     ParticipantRole @default(VOTER)
  joinedAt DateTime        @default(now())

  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  votes Vote[]

  @@unique([roomId, userId])
  @@index([roomId])
}

model Ticket {
  id            String       @id @default(cuid())
  title         String
  externalKey   String?
  description   String?
  finalEstimate String?
  status        TicketStatus @default(PENDING)
  order         Int          @default(0)

  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  rounds Round[]

  @@index([roomId])
}

model Round {
  id         String      @id @default(cuid())
  status     RoundStatus @default(VOTING)
  startedAt  DateTime    @default(now())
  revealedAt DateTime?

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  votes Vote[]

  @@index([ticketId])
}

model Vote {
  id        String   @id @default(cuid())
  value     String
  createdAt DateTime @default(now())

  roundId String
  round   Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)

  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([roundId, participantId])
  @@index([roundId])
}
