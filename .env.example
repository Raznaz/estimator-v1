# PostgreSQL (используется docker-compose.yml и Prisma)
POSTGRES_USER=estimator
POSTGRES_PASSWORD=estimator
POSTGRES_DB=estimator
POSTGRES_PORT=5432

# Строка подключения Prisma (должна совпадать с кредами выше)
DATABASE_URL=postgresql://estimator:estimator@localhost:5432/estimator?schema=public

# Backend (NestJS)
API_PORT=3001
CORS_ORIGIN=http://localhost:3000

# Frontend (Next.js) — публичные переменные
NEXT_PUBLIC_API_URL=http://localhost:3001
